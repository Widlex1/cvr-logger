<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background_dark"
    android:fitsSystemWindows="true">

    <!-- Top Toolbar -->
    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/toolbar_settings"
        android:layout_width="match_parent"
        android:layout_height="50dp"
        android:layout_margin="12dp"
        android:background="@drawable/border_pink"
        android:paddingHorizontal="12dp"
        app:layout_constraintTop_toTopOf="parent">

        <ImageView
            android:id="@+id/btn_back"
            android:layout_width="20dp"
            android:layout_height="20dp"
            android:src="@android:drawable/ic_menu_revert"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:tint="@color/footer_gray" />

        <TextView
            android:id="@+id/tv_settings_title"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="16dp"
            android:text="SYSTEM CONFIGURATION"
            android:textColor="@color/accent_pink"
            android:textSize="14sp"
            android:textStyle="bold"
            android:fontFamily="monospace"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toEndOf="@id/btn_back"
            app:layout_constraintTop_toTopOf="parent" />

    </androidx.constraintlayout.widget.ConstraintLayout>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        app:layout_constraintBottom_toTopOf="@id/btn_save"
        app:layout_constraintTop_toBottomOf="@id/toolbar_settings">

        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:padding="24dp">

            <!-- SECTION: USER -->
            <TextView
                android:id="@+id/sec_user"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="ENTITY CONFIGURATION"
                android:textColor="@color/accent_pink"
                android:textSize="12sp"
                android:alpha="0.7"
                android:fontFamily="monospace"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent" />

            <TextView
                android:id="@+id/tv_label_default_user"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:text="DEFAULT NAME:"
                android:textColor="@color/footer_gray"
                android:textSize="12sp"
                android:fontFamily="monospace"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@id/sec_user" />

            <EditText
                android:id="@+id/et_default_user"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:background="@drawable/border_pink"
                android:fontFamily="monospace"
                android:hint="System"
                android:padding="12dp"
                android:textColor="@color/terminal_white"
                android:textColorHint="@color/footer_gray"
                android:textSize="14sp"
                app:layout_constraintTop_toBottomOf="@id/tv_label_default_user" />

            <!-- SECTION: UI -->
            <TextView
                android:id="@+id/sec_ui"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="32dp"
                android:text="INTERFACE OPTIMIZATION"
                android:textColor="@color/accent_pink"
                android:textSize="12sp"
                android:alpha="0.7"
                android:fontFamily="monospace"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@id/et_default_user" />

            <TextView
                android:id="@+id/tv_label_ui_scale"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:text="INTERFACE SCALE:"
                android:textColor="@color/footer_gray"
                android:textSize="12sp"
                android:fontFamily="monospace"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@id/sec_ui" />

            <com.google.android.material.slider.Slider
                android:id="@+id/slider_ui_scale"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:valueFrom="0.8"
                android:valueTo="1.2"
                android:stepSize="0.1"
                android:value="1.0"
                app:thumbColor="@color/accent_pink"
                app:trackColorActive="@color/accent_pink"
                app:trackColorInactive="@color/card_border"
                app:layout_constraintTop_toBottomOf="@id/tv_label_ui_scale" />

            <TextView
                android:id="@+id/tv_label_accent"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:text="THEME ACCENT:"
                android:textColor="@color/footer_gray"
                android:textSize="12sp"
                android:fontFamily="monospace"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@id/slider_ui_scale" />

            <HorizontalScrollView
                android:id="@+id/scroll_accents"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                app:layout_constraintTop_toBottomOf="@id/tv_label_accent">

                <LinearLayout
                    android:id="@+id/layout_accent_options"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:paddingBottom="8dp" />
            </HorizontalScrollView>

            <!-- SECTION: EDITING -->
            <TextView
                android:id="@+id/sec_editing"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="32dp"
                android:text="DATA INPUT PARAMETERS"
                android:textColor="@color/accent_pink"
                android:textSize="12sp"
                android:alpha="0.7"
                android:fontFamily="monospace"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@id/scroll_accents" />

            <com.google.android.material.materialswitch.MaterialSwitch
                android:id="@+id/switch_enter_send"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:text="ENTER KEY SENDS DATA"
                android:textColor="@color/terminal_white"
                app:thumbTint="@color/accent_pink"
                app:trackTint="@color/footer_gray"
                android:fontFamily="monospace"
                android:textSize="14sp"
                app:layout_constraintTop_toBottomOf="@id/sec_editing" />

            <!-- SECTION: SECURITY -->
            <LinearLayout
                android:id="@+id/layout_security_section"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:visibility="visible"
                android:layout_marginTop="32dp"
                app:layout_constraintTop_toBottomOf="@id/switch_enter_send">

                <TextView
                    android:id="@+id/sec_security"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="ENCRYPTION PROTOCOLS"
                    android:textColor="@color/accent_pink"
                    android:textSize="12sp"
                    android:alpha="0.7"
                    android:fontFamily="monospace" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    android:text="ACCESS PIN:"
                    android:textColor="@color/footer_gray"
                    android:textSize="12sp"
                    android:fontFamily="monospace" />

                <EditText
                    android:id="@+id/et_access_pin"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:background="@drawable/border_pink"
                    android:fontFamily="monospace"
                    android:hint="4-Digit PIN"
                    android:inputType="numberPassword"
                    android:maxLength="4"
                    android:padding="12dp"
                    android:textColor="@color/terminal_white"
                    android:textColorHint="@color/footer_gray"
                    android:textSize="14sp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    android:text="SECRET RECOVERY WORD:"
                    android:textColor="@color/footer_gray"
                    android:textSize="12sp"
                    android:fontFamily="monospace" />

                <EditText
                    android:id="@+id/et_secret_word"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:background="@drawable/border_pink"
                    android:fontFamily="monospace"
                    android:hint="Secret Word"
                    android:inputType="textPassword"
                    android:padding="12dp"
                    android:textColor="@color/terminal_white"
                    android:textColorHint="@color/footer_gray"
                    android:textSize="14sp" />

            </LinearLayout>

        </androidx.constraintlayout.widget.ConstraintLayout>
    </ScrollView>

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btn_save"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:layout_margin="24dp"
        android:backgroundTint="@color/card_bg"
        android:text="SYNCHRONIZE CHANGES"
        android:textColor="@color/accent_pink"
        android:fontFamily="monospace"
        app:cornerRadius="12dp"
        app:strokeColor="@color/accent_pink"
        app:strokeWidth="1dp"
        app:layout_constraintBottom_toBottomOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>