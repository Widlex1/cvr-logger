<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@color/background_dark">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="24dp">

        <TextView
            android:id="@+id/tv_settings_title"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="SYSTEM CONFIGURATION"
            android:textColor="@color/accent_pink"
            android:textSize="18sp"
            android:textStyle="bold"
            android:fontFamily="monospace"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

        <!-- Default User Setting -->
        <TextView
            android:id="@+id/tv_label_default_user"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:text="DEFAULT ENTITY NAME:"
            android:textColor="@color/footer_gray"
            android:textSize="12sp"
            android:fontFamily="monospace"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/tv_settings_title" />

        <EditText
            android:id="@+id/et_default_user"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:background="@drawable/border_pink"
            android:fontFamily="monospace"
            android:hint="System"
            android:padding="12dp"
            android:textColor="@color/terminal_white"
            android:textColorHint="@color/footer_gray"
            android:textSize="14sp"
            app:layout_constraintTop_toBottomOf="@id/tv_label_default_user" />

        <!-- UI Scaling Setting -->
        <TextView
            android:id="@+id/tv_label_ui_scale"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:text="INTERFACE SCALE PROTOCOL:"
            android:textColor="@color/footer_gray"
            android:textSize="12sp"
            android:fontFamily="monospace"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/et_default_user" />

        <com.google.android.material.slider.Slider
            android:id="@+id/slider_ui_scale"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:valueFrom="0.8"
            android:valueTo="1.2"
            android:stepSize="0.1"
            android:value="1.0"
            app:thumbColor="@color/accent_pink"
            app:trackColorActive="@color/accent_pink"
            app:trackColorInactive="@color/card_border"
            app:layout_constraintTop_toBottomOf="@id/tv_label_ui_scale" />

        <!-- Accent Color Setting -->
        <TextView
            android:id="@+id/tv_label_accent"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:text="THEME ACCENT PROTOCOL:"
            android:textColor="@color/footer_gray"
            android:textSize="12sp"
            android:fontFamily="monospace"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/slider_ui_scale" />

        <HorizontalScrollView
            android:id="@+id/scroll_accents"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            app:layout_constraintTop_toBottomOf="@id/tv_label_accent">

            <LinearLayout
                android:id="@+id/layout_accent_options"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:paddingBottom="8dp" />
        </HorizontalScrollView>

        <!-- AI Toggle -->
        <com.google.android.material.materialswitch.MaterialSwitch
            android:id="@+id/switch_ai"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:text="ENABLE AI CORE (GEMMA)"
            android:textColor="@color/terminal_white"
            android:fontFamily="monospace"
            android:textSize="14sp"
            app:layout_constraintTop_toBottomOf="@id/scroll_accents" />

        <!-- AI Personality -->
        <TextView
            android:id="@+id/tv_label_prompt"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:text="AI PERSONALITY PROTOCOL:"
            android:textColor="@color/footer_gray"
            android:textSize="12sp"
            android:fontFamily="monospace"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/switch_ai" />

        <EditText
            android:id="@+id/et_ai_prompt"
            android:layout_width="match_parent"
            android:layout_height="100dp"
            android:layout_marginTop="8dp"
            android:background="@drawable/border_pink"
            android:fontFamily="monospace"
            android:gravity="top"
            android:hint="Define AI behavior..."
            android:padding="12dp"
            android:textColor="@color/terminal_white"
            android:textColorHint="@color/footer_gray"
            android:textSize="12sp"
            app:layout_constraintTop_toBottomOf="@id/tv_label_prompt" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_settings_cancel"
            style="@style/Widget.Material3.Button.TextButton"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:text="ABORT"
            android:textColor="@color/footer_gray"
            android:fontFamily="monospace"
            app:layout_constraintEnd_toStartOf="@id/btn_settings_save"
            app:layout_constraintTop_toBottomOf="@id/et_ai_prompt" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_settings_save"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:backgroundTint="@color/card_bg"
            android:text="SAVE"
            android:textColor="@color/accent_pink"
            android:fontFamily="monospace"
            app:cornerRadius="4dp"
            app:strokeColor="@color/accent_pink"
            app:strokeWidth="1dp"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toBottomOf="@id/et_ai_prompt" />

    </androidx.constraintlayout.widget.ConstraintLayout>
</ScrollView>